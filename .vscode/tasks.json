{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev-start",
			"type": "shell",
			"command": "npm run start",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "dev-lint",
			"type": "shell",
			"command": "npm",
			"args": ["run", "lint"],
			"isBackground": false
		},
		{
			"label": "deps-install",
			"type": "shell",
			"command": "npm",
			"args": ["install"],
			"isBackground": false
		},
		{
			"label": "eas-build-android",
			"type": "shell",
			"command": "npx",
			"args": ["eas", "build", "--platform", "android", "--profile", "production"],
			"isBackground": false
		},
		{
			"label": "eas-build-ios",
			"type": "shell",
			"command": "npx",
			"args": ["eas", "build", "--platform", "ios", "--profile", "production"],
			"isBackground": false
		},
		{
			"label": "eas-update-production",
			"type": "shell",
			"command": "npx",
			"args": ["eas", "update", "--branch", "production"],
			"isBackground": false
		}
	]
}
